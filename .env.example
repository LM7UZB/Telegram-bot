# ============================================================
# TillaBazar Telegram Bot — sozlamalar
# Bu faylni nusxalab .env deb nomlang va qiymatlarni to'ldiring.
# ============================================================

# 1) BotFather'dan olingan bot tokeni (MAJBURIY)
#    @BotFather -> /newbot -> token: 123456789:AAE...
BOT_TOKEN=

# 2) Web ilova manzili (MAJBURIY, HTTPS bo'lishi shart)
#    Bu — shu servis deploy qilingan ommaviy URL.
#    Masalan Render'da: https://tillabazar.onrender.com
WEBAPP_URL=

# 3) Adminning Chat ID raqami (TAVSIYA ETILADI)
#    Ilovadagi "Sotish" / "Bizga sotish" arizalari shu chatga yuboriladi.
#    Chat ID ni bilish uchun @userinfobot ga /start yuboring.
ADMIN_CHAT_ID=

# 4) Server porti (ixtiyoriy, Render/Railway o'zi belgilaydi)
PORT=3000
